<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup is disabled at the application level (android:allowBackup="false").
  This legacy auto-backup ruleset (used on devices below API 31) is a safety
  net: if backup is ever re-enabled, every domain is excluded so that private
  keys, MLS state, message history, and the active-account SharedPreferences
  never leave the device.
-->
<full-backup-content>
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
</full-backup-content>
