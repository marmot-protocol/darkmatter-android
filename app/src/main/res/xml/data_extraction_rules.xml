<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup is disabled at the application level (android:allowBackup="false").
  These rules exist as a safety net: if a future change re-enables backup,
  the rules below still exclude private key material, MLS group state,
  message history, and the active-account SharedPreferences.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
